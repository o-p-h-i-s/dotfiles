## default
alias sudo='sudo '
alias vim='nvim '
alias edit='vim'
alias rmf='rm -rf'
alias so='source'
alias to='touch'
alias ls='ls --color=auto'
alias ll='ls -alF'
alias ..='cd ..'
alias ...='cd ../..'
alias cdd='cd ~/dotfiles'
alias cdg='cd ~/git'

## rc
# zsh
alias ez='edit ~/dotfiles/rc/.zshrc'
alias sz='so ~/dotfiles/rc/.zshrc'
alias eza='edit ~/dotfiles/rc/.zsh/aliases.zsh'
alias ezc='edit ~/dotfiles/rc/.zsh/scripts.zsh'
alias ezs='edit ~/dotfiles/rc/.zsh/sets.zsh'
# window manager
alias ex='edit ~/dotfiles/rc/.xmonad/xmonad.hs'
# terminal
alias ek='edit ~/dotfiles/rc/.config/kitty/kitty.conf'

## expand
alias mkcd='mkdircd'
alias ec='add_authors_to_cargo'
